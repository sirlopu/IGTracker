{
  "name": "igtracker",
  "version": "0.1.0",
  "description": "Local Instagram follower tracker — runs on your device, no password sharing",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "cross-env ELECTRON_DEV=1 electron .",
    "build": "vite build && electron-builder"
  },
  "dependencies": {
    "sql.js": "^1.10.3",
    "playwright": "^1.42.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.1.4"
  },
  "build": {
    "appId": "com.igtracker.app",
    "productName": "IGTracker",
    "icon": "assets/icons/icon",
    "directories": { "output": "dist-electron" },
    "files": ["electron/**/*", "dist/**/*"],
    "mac": { "category": "public.app-category.utilities", "icon": "assets/icons/icon.icns" },
    "win": { "target": "nsis", "icon": "assets/icons/icon.ico" },
    "linux": { "target": "AppImage", "icon": "assets/icons/icon.png" }
  }
}
